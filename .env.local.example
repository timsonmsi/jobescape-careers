# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jobescape_careers?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# AI (Anthropic or OpenAI)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""
FROM_EMAIL="noreply@jobescape.com"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"

# Google (optional for Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
